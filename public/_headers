/*
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' data: blob:; style-src 'self' 'unsafe-inline'; font-src 'self' data:; img-src 'self' data: https:; connect-src 'self' https: wss:; frame-src 'self' https://player.cloudinary.com; worker-src 'self' blob: data:; media-src 'self' blob: data:
  Referrer-Policy: same-origin
  X-Content-Type-Options: nosniff

# Self-hosted fonts: discourage hotlinking and disable caching by third parties
/_nuxt/*.woff
  Access-Control-Allow-Origin: https://helpr.ai
  Cache-Control: public, max-age=31536000, immutable
  X-Robots-Tag: noindex
/_nuxt/*.woff2
  Access-Control-Allow-Origin: https://helpr.ai
  Cache-Control: public, max-age=31536000, immutable
  X-Robots-Tag: noindex
